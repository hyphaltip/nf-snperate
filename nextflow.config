/*
========================================================================================
    SNPERATE Pipeline Configuration
    Nextflow configuration for SNP calling and population genomics
========================================================================================
*/

manifest {
    name = 'snperate'
    description = 'SNP calling and population genomics pipeline for fungal pathogens'
    author = 'Jason Stajich'
    homePage = 'https://github.com/jstajich/snperate'
    version = '1.0.0'
}

// Default parameters
params {
    // Input files
    samples = "samples.csv"
    population_yaml = "population_sets.yaml"

    // Reference genome
    genome_folder = "genome"
    genome_name = "Af293"
    genome_version = "FungiDB-50"

    // Output directories
    outdir = "results"
    align_folder = "aln"
    gvcf_folder = "gvcf"
    vcf_folder = "vcf"
    coverage_folder = "coverage"
    unmapped_folder = "unmapped"

    // Analysis options
    filter_method = "gatk"  // "gatk" or "bcftools"
    mosdepth_windows = [5000, 10000, 50000]

    // Read group information
    rg_center = "NCBI"
    rg_platform = "Illumina"

    // VCF prefix
    prefix = "snperate"
}

// Process executor configuration
process {
    executor = 'slurm'
    queue = 'short'
    clusterOptions = '--nodes=1'

    withLabel: index {
        cpus = 4
        memory = '8 GB'
        time = '1h'
    }

    withLabel: align {
        cpus = 8
        memory = '32 GB'
        time = '8h'
    }

    withLabel: gvcf {
        cpus = 8
        memory = '48 GB'
        time = '48h'
    }

    withLabel: genomicsdb {
        cpus = 8
        memory = '32 GB'
        time = '24h'
    }

    withLabel: genotype {
        cpus = 4
        memory = '24 GB'
        time = '12h'
    }

    withLabel: select {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withLabel: filter {
        cpus = 2
        memory = '8 GB'
        time = '4h'
    }

    withLabel: vcf {
        cpus = 4
        memory = '8 GB'
        time = '4h'
    }

    withLabel: cnv {
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }
}

// Docker/Singularity container (optional)
// docker.enabled = true
// singularity.enabled = true

// Timeline and report
timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}

// Software versions (for documentation)
software_versions {
    bwa = "0.7.17"
    samtools = "1.12"
    gatk = "4.6.1.0"
    bcftools = "1.12"
    mosdepth = "0.3.6"
}
